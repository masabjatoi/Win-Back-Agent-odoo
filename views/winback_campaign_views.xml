<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View for winback.campaign -->
    <record id="view_winback_campaign_tree" model="ir.ui.view">
        <field name="name">winback.campaign.tree</field>
        <field name="model">winback.campaign</field>
        <field name="arch" type="xml">
            <list string="Win-Back Campaigns">
                <header>
                    <button name="action_run_winback_agent" string="Run Win-Back Agent" type="object" class="btn-primary"/>
                </header>
                <field name="partner_id"/>
                <field name="stage" widget="badge" decoration-info="stage in ('email_1_sent', 'email_2_sent', 'email_3_sent')" decoration-success="stage == 'reactivated'" decoration-warning="stage in ('replied', 'cold', 'opt_out')"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-warning="status == 'pending_review'" decoration-danger="status in ('suppressed', 'failed')"/>
                <field name="email_1_sent_date"/>
                <field name="email_2_sent_date"/>
                <field name="email_3_sent_date"/>
                <field name="suppression_reason"/>
            </list>
        </field>
    </record>

    <!-- Form View for winback.campaign -->
    <record id="view_winback_campaign_form" model="ir.ui.view">
        <field name="name">winback.campaign.form</field>
        <field name="model">winback.campaign</field>
        <field name="arch" type="xml">
            <form string="Win-Back Campaign">
                <header>
                    <button name="action_run_winback_agent" string="Run Win-Back Agent" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Campaign Info">
                            <field name="partner_id"/>
                            <field name="stage"/>
                            <field name="status"/>
                        </group>
                        <group string="Suppression Details">
                            <field name="suppression_reason" readonly="status != 'suppressed'"/>
                        </group>
                    </group>
                    <group string="Outreach Timeline">
                        <group>
                            <field name="email_1_sent_date"/>
                            <field name="email_2_sent_date"/>
                        </group>
                        <group>
                            <field name="email_3_sent_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for winback.campaign -->
    <record id="action_winback_campaign" model="ir.actions.act_window">
        <field name="name">Win-Back Campaigns</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">winback.campaign</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No win-back campaign tracking records found.
            </p>
            <p>
                The campaign agent creates and manages these records automatically.
            </p>
        </field>
    </record>

    <!-- Menu Item for winback.campaign under Lisa Win-Back Root -->
    <menuitem id="menu_lisa_winback_campaigns" 
              name="Campaigns" 
              parent="menu_lisa_winback_root" 
              action="action_winback_campaign" 
              sequence="10"/>
</odoo>
